<h1><%= @plan.name %></h1>

<p><strong>Interval:</strong> <%= @plan.interval %></p>
<p><strong>Price:</strong> <%= @plan.amount_cents %> <%= @plan.currency.upcase %></p>
<p><strong>Status:</strong> <%= @plan.active? ? 'Active' : 'Inactive' %></p>

<%= link_to 'Edit', edit_plan_path(@plan) %>
<%= link_to 'Back', plans_path %>
