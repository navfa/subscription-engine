<%= turbo_stream_from 'subs_engine_subscriptions' %>
<div class="subs-engine-dashboard">
  <h1>Billing Dashboard</h1>

  <div class="subs-engine-metrics">
    <%= render MetricCardComponent.new(
      label: 'Monthly Recurring Revenue',
      value: number_to_currency(@mrr / 100.0),
      style: :positive
    ) %>
    <%= render MetricCardComponent.new(
      label: 'Active Subscriptions',
      value: @active_count
    ) %>
    <%= render MetricCardComponent.new(
      label: 'Churn Rate (30d)',
      value: "#{@churn_rate}%",
      style: @churn_rate > 5 ? :negative : :default
    ) %>
  </div>

  <%= render MrrChartComponent.new(data: @mrr_data) %>

  <h2>Subscriptions</h2>
  <%= render SubscriptionTableComponent.new(
    subscriptions: @subscriptions,
    current_status: @subscription_status,
    page: @subscription_page,
    total: @subscription_total,
    per_page: @subscription_per_page
  ) %>
</div>
