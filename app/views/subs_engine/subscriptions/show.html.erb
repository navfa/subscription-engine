<h1>Subscription</h1>

<p><strong>Plan:</strong> <%= @subscription.plan.name %></p>
<p><strong>Status:</strong> <%= @subscription.current_state %></p>
<p><strong>Period:</strong> <%= @subscription.current_period_start&.to_date %> — <%= @subscription.current_period_end&.to_date %></p>

<% if @subscription.can_transition_to?(:canceled) %>
  <%= button_to "Cancel Subscription", subscription_path(@subscription), method: :delete,
      data: { turbo_confirm: "Are you sure?" } %>
<% end %>

<%= link_to "Back to Plans", plans_path %>
